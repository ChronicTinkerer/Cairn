# Cairn packaging manifest.
# Consumed by BigWigsMods/packager v2 (see .github/workflows/release.yml).
# Reference: https://github.com/BigWigsMods/packager

# Folder name inside the published zip. Must match the .toc filename so WoW
# can load the addon under the same name on user installs.
package-as: Cairn

# Don't ship dev/build infrastructure or editor state to end users.
#  - .dev/         All dev-local artifacts: release.ps1, intermediate dumps,
#                  caches, configs. One folder, one ignore line.
#  - SESSION_NOTES.md is project-internal, not user-facing
#  - editor/IDE folders never ship
#  - scratch/tmp dirs are local workspace junk
ignore:
  - .dev
  - .vscode
  - .idea
  - SESSION_NOTES.md
  - "*.bat"
  - "*.ps1"
  - scratch
  - tmp
  # Wago rejects packages whose TOC filenames carry a flavor suffix it
  # doesn't recognize ("We found different named TOC files in your addon").
  # `_XPTR` is not a WoW-canonical flavor (Mainline / Mists / TBC /
  # Vanilla / Wrath / Cata are). XPTR support stays in our local working
  # tree for dev installs but never enters the published zip.
  - "*_XPTR.toc"

# We do NOT use @project-version@ substitution in the .toc -- the version
# field carries our sequential build number (+1 per .dev/release.ps1 run,
# replacing the legacy YYMMDDHHMM stamp on 2026-05-06). The packager will
# leave a hardcoded `## Version:` line untouched, so no `enable-toc-creation`
# or `move-out-of-package-as` directives are needed.

# License is MIT; ship it inside the package so embedders see it.
# (LICENSE is at the repo root and lives inside package-as by default.)
