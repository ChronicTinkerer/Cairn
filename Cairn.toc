Libs\LibSharedMedia-3.0\LibSharedMedia-3.0.lua
CairnMedia\Cairn-Media.lua
CairnMedia\Cairn-Media-Icons.lua
CairnSettings\Cairn-Settings.lua

# ----- Cairn-Gui-2.0 family (verbatim port from original Cairn d89e0ad)
# Load order matters: lib registration first, then Mixins (Base must exist
# before any widget Mixin builds on it), then Core, then Layouts, then
# Widget bundles, then Layouts-Extra, then Theme.
